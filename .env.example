# ============================================================================
# AI FITNESS TRAINER API - ENVIRONMENT VARIABLES (EXAMPLE)
# ============================================================================
# This is a template file. Copy this to .env and fill in your actual values.
# This file is safe to commit to git (contains no real credentials).
# ============================================================================

# ----------------------------------------------------------------------------
# SUPABASE DATABASE CONFIGURATION
# ----------------------------------------------------------------------------
# Get these from your Supabase project dashboard:
# 1. Go to https://supabase.com/dashboard
# 2. Select your project
# 3. Go to Settings > API
# 4. Copy the URL and service_role key (NOT the anon key)

SUPABASE_URL=your-project-url.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ----------------------------------------------------------------------------
# AI MODEL CONFIGURATION
# ----------------------------------------------------------------------------
# Path to the directory containing your trained pose detection models
# This should contain files like: best_model.keras, label_encoder.npy, etc.

MODEL_DIR=./trained_pose_model

# ----------------------------------------------------------------------------
# SECURITY CONFIGURATION
# ----------------------------------------------------------------------------
# Secret key for JWT token signing
# Generate a secure key with: openssl rand -hex 32
# IMPORTANT: Change this in production!

SECRET_KEY=change-this-in-production-use-openssl-rand-hex-32

# ----------------------------------------------------------------------------
# ENVIRONMENT CONFIGURATION
# ----------------------------------------------------------------------------
# Options: development, staging, production

ENVIRONMENT=development

# ----------------------------------------------------------------------------
# FRONTEND CONFIGURATION
# ----------------------------------------------------------------------------
# URLs of your React frontend (for CORS)

FRONTEND_URL=http://localhost:3000
FRONTEND_URL_ALT=http://localhost:5173
